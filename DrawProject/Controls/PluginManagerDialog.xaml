<Window
    x:Class="DrawProject.Controls.PluginManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:DrawProject.Converters"
    Title="Управление плагинами"
    Width="500"
    Height="350"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:ObjectToBoolConverter x:Key="ObjectToBoolConverter" />
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Заголовок  -->
        <TextBlock
            Margin="0,0,0,10"
            FontWeight="Bold"
            Text="Включите или отключите плагины:" />

        <!--  Список плагинов  -->
        <ListView
            Grid.Row="1"
            BorderThickness="1"
            ItemsSource="{Binding Plugins}"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel
                        Margin="5,5,5,5"
                        Orientation="Horizontal"
                        SnapsToDevicePixels="True">
                        <!--  Чекбокс включения/отключения плагина  -->
                        <CheckBox
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            IsChecked="{Binding IsEnabled}"
                            ToolTip="Включить/отключить плагин" />

                        <!--  Кнопка выгрузки  -->
                        <Button
                            Margin="0,0,8,0"
                            Padding="8,3"
                            VerticalAlignment="Center"
                            Command="{Binding UnloadCommand}"
                            Content="Выгрузить"
                            IsEnabled="{Binding CanUnload}"
                            ToolTip="Выгрузить плагин из памяти" />

                        <!--  Основная информация о плагине  -->
                        <StackPanel VerticalAlignment="Center">
                            <!--  Имя и автор на одной строке  -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,5,0"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Text="{Binding Name}"
                                    ToolTip="Имя плагина" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="#666"
                                    Text="{Binding Author}"
                                    ToolTip="Автор" />
                            </StackPanel>

                            <!--  Описание плагина  -->
                            <TextBlock
                                MaxWidth="400"
                                FontSize="11"
                                Foreground="#444"
                                Text="{Binding Description}"
                                TextWrapping="Wrap"
                                ToolTip="Описание" />

                            <!--  Путь к файлу плагина  -->
                            <TextBlock
                                MaxWidth="400"
                                FontSize="10"
                                Foreground="#999"
                                Text="{Binding PluginPath}"
                                TextWrapping="Wrap"
                                ToolTip="{Binding Path}" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!--  Кнопки  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,10,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="0,0,5,0"
                Padding="20,5"
                Click="OkButton_Click"
                Content="OK"
                IsDefault="True" />
            <!--<Button
            Padding="20,5"
            Click="CancelButton_Click"
            Content="Отмена"
            IsCancel="True" />-->
        </StackPanel>
    </Grid>
</Window>